# .env.example - Template for environment variables
# Copy this to .env and fill in your actual values

# Database Connection
SUPABASE_CONNECTION_STRING=your_connection_string_here

# JWT Configuration
JWT_KEY=your_jwt_secret_key_minimum_32_characters
JWT_ISSUER=PetCare.API
JWT_AUDIENCE=PetCare.Client
JWT_EXPIRES_MINUTES=60

# PayOS Configuration
PAYOS_CLIENT_ID=7a7dbe9d-dfb7-4752-81a7-c7ad9baa95be
PAYOS_API_KEY=384cdee4-d64d-4295-9367-9d97f587660b
PAYOS_CHECKSUM_KEY=aae76ae94178174886ec2a8cfd5b4195038dff40a8bae94f3f14b3920dfb298a

# PayOS URLs
PayOS__ReturnUrl=https://swp-391-pet-suba.vercel.app
PayOS__CancelUrl=https://swp-391-pet-suba.vercel.app
PayOS__CheckoutReturnUrl=https://swp-391-pet-suba.vercel.app
PayOS__CheckoutCancelUrl=https://swp-391-pet-suba.vercel.app

# Environment
ASPNETCORE_ENVIRONMENT=Development

# CORS - comma-separated list of allowed frontend origins (no trailing slash)
# Example: https://swp-391-pet-suba.vercel.app,https://www.swp-391-pet-suba.vercel.app
ALLOWED_ORIGINS=https://swp-391-pet-suba.vercel.app,https://www.swp-391-pet-suba.vercel.app,http://localhost:5173
